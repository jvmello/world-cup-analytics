POSTGRES_DB=worldcup
POSTGRES_USER=worldcup
POSTGRES_PASSWORD=worldcup
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_INTERNAL_PORT=5432

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

JUPYTER_PORT=8888
STREAMLIT_PORT=8501
WEB_PORT=8010

# CORS allow-list for the web API (comma-separated). Never use "*" in
# production. Add http://localhost:${WEB_PORT} only for local development.
ALLOWED_ORIGINS=https://worldcup.jvmello.dev,http://localhost:8010

# Internal curation tools. Keep disabled on public deployments unless the route
# is protected. ADMIN_API_KEY is required for shared environments.
ENABLE_ADMIN_TOOLS=false
ADMIN_API_KEY=replace_with_a_long_random_key
ADMIN_DATABASE_PATH=data/admin/world_cup_admin.db

THESTATSAPI_API_KEY=replace_me
THESTATSAPI_BASE_URL=https://api.thestatsapi.com/api

# Optional. Defaults to PostgreSQL from POSTGRES_* when available, otherwise
# sqlite:///data/ingestion/world_cup_ingestion.db.
# THESTATSAPI_DATABASE_URL=postgresql://worldcup:worldcup@postgres:5432/worldcup
# THESTATSAPI_DATABASE_URL=sqlite:///data/ingestion/world_cup_ingestion.db
